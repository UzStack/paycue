APP_ID=<app_id>
APP_HASH=<app_hash>
PORT=8080
DB_PATH=./db.sqlite3
SESSION_DIR=sessions
WORKERS=10
TRANSACTION_TIMEOUT=30
DEBUG=false
CORS_ORIGIN=*
WEB_DIR=

# Noyob to'lov summasi tiyin qadamida tanlanadi (1000.00, 1000.01, ... 1000.99, 1001.00).
# AMOUNT_DIRECTION=up   -> summa yuqoriga o'sadi (default)
# AMOUNT_DIRECTION=down -> summa pastga kamayadi (1000.00, 999.99, ...)
AMOUNT_DIRECTION=up

# Telemetriya (anonim foydalanish statistikasi — maxfiy ma'lumotsiz, faqat sanoqlar)
STATS_URL=https://paycue.uz   # hisobot yuboriladigan kollektor
STATS_REPORT=true             # bu instance anonim statistikasini yuboradimi (false bilan o'chiriladi)
STATS_DASHBOARD=false         # bu instance hisobotlarni qabul qilib UI'da ko'rsatadimi (default o'chiq)
